{
  "_meta": {
    "file": "docs/backend-map/entities_from_dictionaries.json",
    "purpose": "Сущности (логические таблицы/агрегаты): имя на русском, описание домена, список полей для проектирования БД и форм.",
    "readme": "docs/backend-map/README.md",
    "companion": "docs/backend-map/small_dictionaries.json",
    "references": [
      "docs/backend-map/small_dictionaries.json"
    ],
    "provenance": "Исторически из бизнес-доков примера (вне репо / по поставкам); актуализация — из analysis_hub/inbox и из docs/ при появлении новых требований.",
    "field_conventions": {
      "key": "machine name поля (camelCase в JSON здесь; в БД может быть snake — решать при миграции).",
      "rus": "подпись в UI/доках.",
      "type": "uuid | string | int | float | boolean | date | datetime | json — логический тип, не привязка к конкретному SQL.",
      "required": "обязательность на уровне модели; бизнес-optional может быть true с пометкой в description.",
      "description": "смысл поля, ref → dictionaries.<name>, связи с другими сущностями, оговорки."
    },
    "entity_shape": {
      "entities": "Ключ объекта = короткий id сущности (snake_case). Значение: name, description?, fields[].",
      "open_questions": "_open_questions в корне — незакрытые продуктовые/модельные вопросы до уточнения."
    },
    "update_rules": [
      "Новая сущность из входящей таблицы — добавить блок в entities, связать FK и справочники в description.",
      "Новое поле — проверить, не является ли значение малым справочником; если да — вынести в small_dictionaries и оставить ref.",
      "Версию version поднимать при осмысленном изменении схемы (minor при добавлениях).",
      "После правок — node scripts/generate-backend-map-overview.cjs (синхронизация OVERVIEW.generated.md)."
    ]
  },
