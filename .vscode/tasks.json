    {
      "label": "frontend: crm-web (nx serve)",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/crm-web",
        "env": {}
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "dev: backend + frontend (parallel)",
      "dependsOn": ["backend: dev", "frontend: crm-web (nx serve)"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
