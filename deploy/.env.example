# Скопируй в `deploy/.env` и замени значения. Файл `.env` в git не коммитится.

BACKEND_PORT=3000
WEB_PORT=8080

# Пароль PostgreSQL (user/db: crm). Должен совпадать с тем, что в DATABASE_URL на backend.
POSTGRES_PASSWORD=crm

# Проброс Postgres на хост (опционально; для отладки). В compose backend ходит во внутреннюю сеть `postgres`.
POSTGRES_PORT=5432

# Если backend и web под одним доменом через nginx (как в этом деплое), можно оставить '*'
# или указать origin (например https://srmweb.com).
CORS_ORIGIN=*

# DATABASE_URL для контейнера backend задаётся в docker-compose.yml (не дублируй здесь, если не переопределяешь).

