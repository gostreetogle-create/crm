# Скопируй в `deploy/.env` и замени значения. Файл `.env` в git не коммитится.
#
# Канон портов (не меняй без согласования с backend/.env — см. docs/dev-local-ports.md):
#   Postgres → 5432, API → 3000, nginx → 8080, nx dev → 4200 (не Docker).

BACKEND_PORT=3000
WEB_PORT=8080

# Пароль PostgreSQL (user/db: crm). Префикс CRM_* — иначе пустая POSTGRES_PASSWORD в Windows может сломать Docker Compose.
CRM_POSTGRES_PASSWORD=crm

# Проброс Postgres на хост. Для dev с backend на машине — совпадайте с DATABASE_URL в backend/.env (канон: 5432).
# На Synology, если «address already in use» на 5432, поставьте например 5433 (внутри compose backend всё равно ходит на postgres:5432).
POSTGRES_PORT=5432

# В контейнере backend NODE_ENV=production: '*' недопустим. Локальный compose (WEB_PORT=8080):
# CORS_ORIGIN=http://localhost:8080
# Прод: https://ваш-домен — тот же origin, который видит браузер (не IP:порт сервера без совпадения).
# Cloudflare Tunnel / reverse proxy: поставьте публичный URL сайта, иначе API отрежет CORS.
CORS_ORIGIN=http://localhost:8080

# Секрет подписи JWT (минимум 16 символов). Пример: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# DATABASE_URL для контейнера backend задаётся в docker-compose.yml (не дублируй здесь, если не переопределяешь).

# BACKUP_DATABASE_URL — DSN для pg_dump/pg_restore в контейнере backend: тот же user/pass/db, что в DATABASE_URL compose, но БЕЗ ?schema=public.
# Хост — имя сервиса postgres (не localhost). Без кавычек вокруг значения.
# Если не задать: код обрежет ?… у встроенного DATABASE_URL (эквивалентно для типичного compose).
# После добавления/смены: docker compose --env-file .env up -d --force-recreate backend
# BACKUP_DATABASE_URL=postgresql://crm:ВАШ_ПАРОЛЬ@postgres:5432/crm
#
# CRM_DEPLOY_DIR — каталог на сервере, где лежит docker-compose.yml (для подсказки в админке, если после restore не сработало авто-переподключение Prisma). По умолчанию /opt/crm/deploy.
# CRM_DEPLOY_DIR=/opt/crm/deploy

# Фронт в проде: не собирается на сервере. Заливайте готовую статику в deploy/prebuilt-web/ (см. deploy/README.md).
# Полная сборка SPA внутри Docker (CI / мощный хост): deploy/Dockerfile.web.in-docker-build — см. комментарий в deploy/README.md.

