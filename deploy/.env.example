# Скопируй в `deploy/.env` и замени значения. Файл `.env` в git не коммитится.
#
# Канон портов (не меняй без согласования с backend/.env — см. docs/dev-local-ports.md):
#   Postgres → 5432, API → 3000, nginx → 8080, nx dev → 4200 (не Docker).

BACKEND_PORT=3000
WEB_PORT=8080

# Пароль PostgreSQL (user/db: crm). Префикс CRM_* — иначе пустая POSTGRES_PASSWORD в Windows может сломать Docker Compose.
CRM_POSTGRES_PASSWORD=crm

# Проброс Postgres на хост. Должен совпадать с портом в DATABASE_URL в backend/.env (канон: 5432).
POSTGRES_PORT=5432

# В контейнере backend NODE_ENV=production: '*' недопустим. Локальный compose (WEB_PORT=8080):
# CORS_ORIGIN=http://localhost:8080
# Прод: https://ваш-домен (как в deploy.sh).
CORS_ORIGIN=http://localhost:8080

# Секрет подписи JWT (минимум 16 символов). Пример: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# DATABASE_URL для контейнера backend задаётся в docker-compose.yml (не дублируй здесь, если не переопределяешь).

# Сборка образа web (Angular/Nx) на VPS: при «Building…» минутами и exit 1 без текста ошибки — чаще всего OOM.
# 1) Включите swap 2–4G (sudo fallocate/swapfile) если RAM ≤4G.
# 2) Оставьте один воркер (по умолчанию в compose) или явно:
# NG_BUILD_MAX_WORKERS=1
# 3) Подберите heap под RAM (оставьте ~1G системе + docker):
# NODE_BUILD_HEAP_MB=2048
# NODE_BUILD_HEAP_MB=3072

