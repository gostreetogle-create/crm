generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id        String     @id @default(uuid())
  name      String
  code      String?
  notes     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  materials Material[]
}

model Color {
  id        String   @id @default(uuid())
  ralCode   String?
  name      String
  hex       String
  rgbR      Int
  rgbG      Int
  rgbB      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characteristics           MaterialCharacteristic[]
  productLineColorOverrides ProductLine[]
}

model SurfaceFinish {
  id             String   @id @default(uuid())
  finishType     String
  roughnessClass String
  raMicron       Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  characteristics MaterialCharacteristic[]
}

model Coating {
  id              String   @id @default(uuid())
  coatingType     String
  coatingSpec     String
  thicknessMicron Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  characteristics MaterialCharacteristic[]
}

model Geometry {
  id          String   @id @default(uuid())
  name        String
  shapeKey    String
  heightMm    Float?
  lengthMm    Float?
  widthMm     Float?
  diameterMm  Float?
  thicknessMm Float?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials Material[]
}

model ProductionWorkType {
  id            String   @id @default(uuid())
  name          String
  shortLabel    String
  hourlyRateRub Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  productionDetailSources      ProductionDetail[] @relation("ProductionDetailSourceWorkType")
  productLineWorkTypeOverrides ProductLine[]      @relation("ProductLineWorkTypeOverride")
}

model Client {
  id                  String   @id @default(uuid())
  lastName            String
  firstName           String
  patronymic          String
  phone               String
  address             String
  email               String
  notes               String   @default("")
  clientMarkupPercent Float?
  isActive            Boolean  @default(true)
  passportSeries      String   @default("")
  passportNumber      String   @default("")
  passportIssuedBy    String   @default("")
  passportIssuedDate  String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organizationLinks OrganizationContact[]
  commercialOffers  CommercialOffer[]
}

model Organization {
  id              String   @id @default(uuid())
  name            String
  shortName       String?
  legalForm       String?
  inn             String?
  kpp             String?
  ogrn            String?
  okpo            String?
  phone           String?
  email           String?
  website         String?
  legalAddress    String?
  postalAddress   String?
  bankName        String?
  bankBik         String?
  bankAccount     String?
  bankCorrAccount String?
  signerName      String?
  signerPosition  String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts          OrganizationContact[]
  commercialOffers  CommercialOffer[]
  kpPhotos          KpPhoto[]
  materialSuppliers Material[]            @relation("MaterialSupplier")
}

/// Изображения для вставки в коммерческое предложение (привязка к организации).
model KpPhoto {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  photoTitle     String
  /// Имя файла в каталоге uploads/kp-photos/{organizationId}/ (без путей; бэкенд проверяет наличие и отдаёт URL).
  photoFileName  String?
  /// Внешний URL или data URL (legacy); если задано photoFileName и файл найден — в API приоритет у файла.
  photoUrl       String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}

enum CommercialOfferStatus {
  DRAFT
  SENT
  ACCEPTED
  CANCELLED
}

enum TradeGoodKind {
  ITEM
  COMPLEX
}

/// Шапка коммерческого предложения (строки позиций — отдельный шаг).
model CommercialOffer {
  id             String                @id @default(uuid())
  number         String?
  title          String?
  status         CommercialOfferStatus @default(DRAFT)
  organizationId String?
  clientId       String?
  validUntil     DateTime?
  currency       String                @default("RUB")
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model OrganizationContact {
  organizationId String
  clientId       String
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@id([organizationId, clientId])
  @@index([clientId])
}

model Role {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int
  notes     String?
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

/// Ключ-значение для глобальных настроек приложения (например матрица прав UI).
model AppSetting {
  key       String   @id @db.VarChar(128)
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(uuid())
  login        String   @unique
  passwordHash String
  fullName     String
  email        String
  phone        String
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)
}

model MaterialCharacteristic {
  id                     String   @id @default(uuid())
  name                   String
  code                   String?
  densityKgM3            Float?
  colorId                String?
  colorName              String?
  colorHex               String?
  surfaceFinishId        String?
  finishType             String?
  roughnessClass         String?
  raMicron               Float?
  coatingId              String?
  coatingType            String?
  coatingSpec            String?
  coatingThicknessMicron Float?
  notes                  String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  color         Color?         @relation(fields: [colorId], references: [id], onDelete: SetNull)
  surfaceFinish SurfaceFinish? @relation(fields: [surfaceFinishId], references: [id], onDelete: SetNull)
  coating       Coating?       @relation(fields: [coatingId], references: [id], onDelete: SetNull)
  materials     Material[]
}

model Material {
  id                       String   @id @default(uuid())
  name                     String
  code                     String?
  unitId                   String?
  purchasePriceRub         Float?
  materialCharacteristicId String
  geometryId               String
  supplierOrganizationId   String?
  notes                    String?
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  unit                    Unit?                  @relation(fields: [unitId], references: [id], onDelete: SetNull)
  characteristic          MaterialCharacteristic @relation(fields: [materialCharacteristicId], references: [id], onDelete: Restrict)
  geometry                Geometry               @relation(fields: [geometryId], references: [id], onDelete: Restrict)
  supplierOrganization    Organization?          @relation("MaterialSupplier", fields: [supplierOrganizationId], references: [id], onDelete: SetNull)
  productionDetailSources ProductionDetail[]     @relation("ProductionDetailSourceMaterial")
}

/// Справочник «Детали»: независимая позиция со снимком полей материала и вида работ (редактируемый снимок).
model ProductionDetail {
  id       String  @id @default(uuid())
  name     String
  code     String?
  qty      Float   @default(1)
  notes    String?
  isActive Boolean @default(true)

  sourceMaterialId String?
  sourceWorkTypeId String?

  snapshotMaterialName       String?
  snapshotMaterialCode       String?
  snapshotUnitCode           String?
  snapshotUnitName           String?
  snapshotPurchasePriceRub   Float?
  snapshotDensityKgM3        Float?
  snapshotHeightMm           Float?
  snapshotLengthMm           Float?
  snapshotWidthMm            Float?
  snapshotDiameterMm         Float?
  snapshotThicknessMm        Float?
  snapshotCharacteristicName String?

  snapshotWorkTypeName   String?
  snapshotWorkShortLabel String?
  snapshotHourlyRateRub  Float?
  workTimeHours          Float?

  materialTotalRub Float?
  workTotalRub     Float?
  lineTotalRub     Float?

  sourceMaterial Material?           @relation("ProductionDetailSourceMaterial", fields: [sourceMaterialId], references: [id], onDelete: SetNull)
  sourceWorkType ProductionWorkType? @relation("ProductionDetailSourceWorkType", fields: [sourceWorkTypeId], references: [id], onDelete: SetNull)
  productLines   ProductLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceMaterialId])
  @@index([sourceWorkTypeId])
}

/// Справочник «Изделия» (производственная BOM к деталям). Таблица в БД: `"Product"`.
model ManufacturedProduct {
  id          String   @id @default(uuid())
  /// Артикул / внутренний код SKU (уникален, если задан).
  code        String?  @unique
  name        String
  /// Текст для витрины и КП; внутренние пометки — в `notes`.
  description String?
  priceRub    Float?
  costRub     Float?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines          ProductLine[]
  tradeGoodLines TradeGoodLine[]

  @@map("Product")
}

/// Коммерческий комплекс: в один комплекс входит несколько каталожных товаров (модель `Product` → таблица `products`).
model Complex {
  id          String   @id @default(uuid())
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  products Product[]

  @@index([isActive, name])
  @@map("complexes")
}

/// Товар в составе комплекса: в товар входит несколько позиций изделий (`Article`).
model Product {
  id          String   @id @default(uuid())
  complexId   String   @map("complex_id")
  name        String
  code        String?
  description String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  complex  Complex   @relation(fields: [complexId], references: [id], onDelete: Restrict)
  articles Article[]

  @@index([complexId])
  @@index([complexId, isActive, name])
  @@map("products")
}

/// Позиция изделия в составе товара (не путать с производственным `ManufacturedProduct`).
model Article {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  name        String
  code        String?
  description String?
  qty         Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([productId, isActive, sortOrder, name])
  @@map("articles")
}

/// Категория товарной номенклатуры (верхний уровень для КП / витрины).
model TradeGoodCategory {
  id        String   @id @default(uuid())
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories TradeGoodSubcategory[]
  tradeGoods    TradeGood[]

  @@unique([name])
  @@map("trade_good_categories")
}

/// Подкатегория внутри категории товаров.
model TradeGoodSubcategory {
  id         String   @id @default(uuid())
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   TradeGoodCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tradeGoods TradeGood[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("trade_good_subcategories")
}

/// Справочник «Товары» (TradeGood): коммерческая позиция из одного или нескольких производственных изделий (`ManufacturedProduct`).
model TradeGood {
  id          String  @id @default(uuid())
  code        String? @unique
  name        String
  description String?
  /// Ссылка на справочник категорий; null — без категории (витрина: «Без категории»).
  categoryId    String? @map("category_id")
  /// Ссылка на подкатегорию; должна принадлежать той же логической ветке, что и categoryId.
  subcategoryId String? @map("subcategory_id")
  /// Единица учёта для клиента (шт, м.п., м² …), без FK на справочник единиц.
  unitCode      String? @map("unit_code")
  priceRub      Float?
  costRub       Float?
  notes         String?
  isActive      Boolean      @default(true)
  kind          TradeGoodKind @default(ITEM)
  /// Какой снимок главный для карточек и КП: `артикул_N.ext` (1 = первый файл `_1`).
  photoPrimaryIndex Int @default(1) @map("photo_primary_index")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    TradeGoodCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory TradeGoodSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  lines            TradeGoodLine[] @relation("TradeGoodParentLines")
  componentInLines TradeGoodLine[] @relation("TradeGoodComponentLines")

  @@index([categoryId])
  @@index([subcategoryId])
  @@map("trade_goods")
}

/// Строка состава товара: изделие и количество.
model TradeGoodLine {
  id          String @id @default(uuid())
  tradeGoodId String
  sortOrder   Int    @default(0)
  productId   String?
  componentTradeGoodId String? @map("component_trade_good_id")
  qty         Float  @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tradeGood          TradeGood            @relation("TradeGoodParentLines", fields: [tradeGoodId], references: [id], onDelete: Cascade)
  product            ManufacturedProduct? @relation(fields: [productId], references: [id], onDelete: Restrict)
  componentTradeGood TradeGood?           @relation("TradeGoodComponentLines", fields: [componentTradeGoodId], references: [id], onDelete: Restrict)

  @@index([tradeGoodId])
  @@index([productId])
  @@index([componentTradeGoodId])
  @@map("trade_good_lines")
}

/// Строка состава изделия: ссылка на деталь + опциональные переопределения вида работ и цвета (null = взять из детали/материала).
model ProductLine {
  id                 String  @id @default(uuid())
  productId          String
  sortOrder          Int     @default(0)
  productionDetailId String
  workTypeId         String?
  colorId            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product          ManufacturedProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionDetail ProductionDetail    @relation(fields: [productionDetailId], references: [id], onDelete: Restrict)
  overrideWorkType ProductionWorkType? @relation("ProductLineWorkTypeOverride", fields: [workTypeId], references: [id], onDelete: SetNull)
  overrideColor    Color?              @relation(fields: [colorId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([productionDetailId])
}
