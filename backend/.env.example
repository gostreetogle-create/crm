PORT=3000
CORS_ORIGIN=*

# Минимум 16 символов. В production обязателен; локально можно не задавать (будет dev-заглушка).
# JWT_SECRET=

# Локально (Postgres в Docker или на хосте). Порт должен совпадать с POSTGRES_PORT в deploy/.env (канон: 5432):
# DATABASE_URL=postgresql://crm:crm@localhost:5432/crm?schema=public

# Опционально: тот же DSN, что DATABASE_URL, но без ?schema=… — для pg_dump/pg_restore (libpq не принимает ?schema=public).
# Если не задано, из DATABASE_URL автоматически отрезается хвост после «?».
# BACKUP_DATABASE_URL=postgresql://crm:crm@localhost:5432/crm

# Каталог файлов бэкапов (pg_dump). По умолчанию ./backups относительно cwd backend.
# BACKUP_DIR=backups

# Сид: создать тестового пользователя director/director (роль «Директор»). В production задайте 0.
# SEED_DIRECTOR_USER=1

# Опционально: дублировать JSON-строки диагностики (ошибки) в файл. См. docs/dev-logs-and-diagnostics.md
# CRM_DIAGNOSTIC_LOG_FILE=
