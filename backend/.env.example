PORT=3000
CORS_ORIGIN=*

# Минимум 16 символов. В production обязателен; локально можно не задавать (будет dev-заглушка).
# JWT_SECRET=

# Локально (Postgres в Docker или на хосте). Порт должен совпадать с POSTGRES_PORT в deploy/.env (канон: 5432):
# DATABASE_URL=postgresql://crm:crm@localhost:5432/crm?schema=public

# BACKUP_DATABASE_URL — строка подключения для pg_dump / pg_restore (обязательно без ?schema=…; libpq её не понимает).
# Задаётся здесь при npm run dev. В Docker задаётся в deploy/.env и пробрасывается в контейнер backend (после смены — --force-recreate).
# Если пусто: берётся DATABASE_URL, всё после первого «?» отбрасывается (часто остаётся localhost для локальной БД).
# Локально типично: @localhost:5432 ; в compose-сети: @postgres:5432 (как в deploy/.env.example).
# BACKUP_DATABASE_URL=postgresql://crm:crm@localhost:5432/crm
#
# CRM_DEPLOY_DIR — только для текста подсказки в UI после restore, если не удалось prisma.$disconnect/$connect (путь к папке с docker-compose).
# CRM_DEPLOY_DIR=/opt/crm/deploy

# Каталог файлов бэкапов (pg_dump). По умолчанию ./backups относительно cwd backend.
# BACKUP_DIR=backups

# Сид: создать тестового пользователя director/director (роль «Директор»). В production задайте 0.
# SEED_DIRECTOR_USER=1

# Опционально: дублировать JSON-строки диагностики (ошибки) в файл. См. docs/dev-logs-and-diagnostics.md
# CRM_DIAGNOSTIC_LOG_FILE=
